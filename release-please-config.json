{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "tag-separator": "-",
  "separate-pull-requests": false,
  "draft": false,
  "prerelease": false,
  "pull-request-header": ":robot: 자동 생성된 Release PR입니다.",
  "pull-request-footer": ":mag: 검토후에 이상이 없으면 릴리즈해주세요.",
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug Fixes"
    },
    {
      "type": "perf",
      "section": "Performance Improvements"
    },
    {
      "type": "refactor",
      "section": "Code Refactoring"
    }
  ],
  "packages": {
    ".": {
      "extra-files": [
        "gradle.properties"
      ]
    }
  }
}
